# ── Python cache files ───────────────────────────────────
# These are automatically generated by Python when you run code
# They have no value in Git — Python recreates them automatically
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Jupyter Notebook checkpoints ─────────────────────────
# Jupyter automatically saves backup copies here
# They are temporary and should not be tracked
.ipynb_checkpoints/

# Data files — tracked by DVC not Git
# Ignore the actual data files but NOT the .dvc pointer files
data/raw/*
data/processed/*

# Allow DVC pointer files and DVC-created .gitignore
!data/raw/.gitignore
!data/raw/*.dvc
!data/processed/.gitignore
!data/processed/*.dvc

# ── Model files — tracked by DVC, not Git ────────────────
# .pkl files are binary — Git cannot diff them efficiently
outputs/models/*
outputs/clusters/*

# Allow DVC pointer files and DVC-created .gitignore
!outputs/models/.gitignore
!outputs/models/*.dvc
!outputs/clusters/.gitignore
!outputs/clusters/*.dvc

# ── Environment files ─────────────────────────────────────
# These contain secret API keys and passwords
# NEVER put these on GitHub
.env
.env.local

# ── Virtual environments ──────────────────────────────────
# These contain thousands of library files
# Your reviewer installs these themselves using requirements.txt
venv/
.venv/
env/

# ── Operating system files ────────────────────────────────
# These are created automatically by Windows and Mac
# They have no meaning for your project
.DS_Store
Thumbs.db
desktop.ini

# ── IDE and editor files ──────────────────────────────────
.vscode/
.idea/
*.swp