# ── Python cache files ────────────────────────────────────
# Auto-generated by Python when running code
# Different on every machine — no value in Git
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Jupyter Notebook checkpoints ──────────────────────────
# Auto-saved backups by Jupyter — temporary, not actual work
.ipynb_checkpoints/

# ── Data files — tracked by DVC, NOT Git ──────────────────
# Ignore actual data files (large binary files)
data/raw/*
data/processed/*

# Allow DVC pointer files and DVC auto-created .gitignore
# These small files MUST go to Git
!data/.gitignore
!data/raw/.gitignore
!data/raw/*.dvc
!data/processed/.gitignore
!data/processed/*.dvc

# ── Model files — tracked by DVC, NOT Git ─────────────────
# .pkl files are binary — Git cannot handle them efficiently
outputs/models/*
outputs/clusters/*

# Allow DVC pointer files and DVC auto-created .gitignore
!outputs/models/.gitignore
!outputs/models/*.dvc
!outputs/clusters/.gitignore
!outputs/clusters/*.dvc

# ── Reports and figures — these GO to Git ─────────────────
# Small image files — safe and useful to version with code
# Intentionally NOT ignored

# ── Environment files ──────────────────────────────────────
# Contain secret keys and passwords — NEVER on GitHub
.env
.env.local

# ── Virtual environments ───────────────────────────────────
# Thousands of library files — reviewer installs via requirements.txt
venv/
.venv/
env/

# ── Operating system files ─────────────────────────────────
# Auto-created by Windows and Mac — no project meaning
.DS_Store
Thumbs.db
desktop.ini

# ── IDE and editor files ───────────────────────────────────
# Personal editor settings — different for every developer
.vscode/
.idea/
*.swp

# MLflow artifacts — large files, not needed in Git
mlruns/